generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model roles {
  role_id          Int                @id @default(autoincrement())
  role_name        String             @unique @db.VarChar(50)
  created_at       DateTime           @default(now())
  deleted_at       DateTime?
  hotel_admins     hotel_admins[]
  hotel_sub_admins hotel_sub_admins[]

  @@map("roles")
}

model system_admins {
  system_admin_id        Int                   @id @default(autoincrement())
  name                   String                @db.VarChar(150)
  email                  String                @unique @db.VarChar(255)
  password               String                @db.VarChar(255)
  is_active              Boolean               @default(true)
  is_blocked             Boolean               @default(false)
  created_by             Int?
  last_login_at          DateTime?
  login_attempts         Int                   @default(0)
  password_reset_token   String?               @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  deleted_at             DateTime?
  hotel_admins           hotel_admins[]
  hotels_approved        hotels[]              @relation("HotelApprovedBy")
  hotels_created         hotels[]              @relation("HotelCreatedBy")
  system_admin_details   system_admin_details?
  creator                system_admins?        @relation("AdminCreatedBy", fields: [created_by], references: [system_admin_id])
  created_admins         system_admins[]       @relation("AdminCreatedBy")

  @@index([email])
  @@index([created_by], map: "system_admins_created_by_fkey")
  @@map("system_admins")
}

model system_admin_details {
  system_admin_details_id Int           @id @default(autoincrement())
  system_admin_id         Int           @unique
  dob                     DateTime?     @db.Date
  gender                  String?       @db.VarChar(20)
  address                 String?       @db.Text
  nid_no                  String?       @db.VarChar(50)
  phone                   String?       @db.VarChar(32)
  image_url               String?       @db.VarChar(500)
  updated_at              DateTime      @updatedAt
  system_admin            system_admins @relation(fields: [system_admin_id], references: [system_admin_id], onDelete: Cascade)

  @@map("system_admin_details")
}

model end_users {
  end_user_id            Int               @id @default(autoincrement())
  email                  String            @unique @db.VarChar(255)
  password               String            @db.VarChar(255)
  name                   String            @db.VarChar(150)
  email_verified         Boolean           @default(false)
  email_verified_at      DateTime?
  is_blocked             Boolean           @default(false)
  last_login_at          DateTime?
  login_attempts         Int               @default(0)
  locked_until           DateTime?
  password_reset_token   String?           @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  deleted_at             DateTime?
  bookings               bookings[]
  end_user_details       end_user_details?

  @@index([email])
  @@map("end_users")
}

model end_user_details {
  end_user_detail_id Int       @id @default(autoincrement())
  end_user_id        Int       @unique
  dob                DateTime? @db.Date
  gender             String?   @db.VarChar(20)
  address            String?   @db.Text
  country            String?   @default("Bangladesh") @db.VarChar(100)
  nid_no             String?   @db.VarChar(50)
  passport           String?   @db.VarChar(50)
  phone              String?   @db.VarChar(32)
  emergency_contact  String?   @db.VarChar(100)
  image_url          String?   @db.VarChar(500)
  updated_at         DateTime  @updatedAt
  end_user           end_users @relation(fields: [end_user_id], references: [end_user_id], onDelete: Cascade)

  @@map("end_user_details")
}

model hotels {
  hotel_id           Int                @id @default(autoincrement())
  name               String             @db.VarChar(255)
  email              String?            @db.VarChar(150)
  address            String?            @db.Text
  city               String?            @db.VarChar(100)
  hotel_type         HotelType?
  emergency_contact1 String?            @db.VarChar(100)
  emergency_contact2 String?            @db.VarChar(100)
  owner_name         String?            @db.VarChar(150)
  zip_code           String?            @db.VarChar(20)
  created_by         Int
  approval_status    ApprovalStatus     @default(DRAFT)
  published_at       DateTime?
  approved_by        Int?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  deleted_at         DateTime?
  bookings           bookings[]
  hotel_admin        hotel_admins?
  hotel_amenities    hotel_amenities[]
  hotel_details      hotel_details?
  hotel_images       hotel_images[]
  hotel_rooms        hotel_rooms[]
  hotel_sub_admins   hotel_sub_admins[]
  approver           system_admins?     @relation("HotelApprovedBy", fields: [approved_by], references: [system_admin_id])
  creator            system_admins      @relation("HotelCreatedBy", fields: [created_by], references: [system_admin_id])

  @@index([approval_status])
  @@index([city])
  @@index([approved_by], map: "hotels_approved_by_fkey")
  @@index([created_by], map: "hotels_created_by_fkey")
  @@map("hotels")
}

model hotel_details {
  hotel_details_id Int      @id @default(autoincrement())
  hotel_id         Int      @unique
  description      String?  @db.Text
  reception_no1    String?  @db.VarChar(32)
  reception_no2    String?  @db.VarChar(32)
  star_rating      Decimal? @db.Decimal(2, 1)
  guest_rating     Decimal  @default(0.00) @db.Decimal(3, 2)
  updated_at       DateTime @updatedAt
  hotel            hotels   @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  @@map("hotel_details")
}

model hotel_admins {
  hotel_admin_id         Int                  @id @default(autoincrement())
  role_id                Int                  @default(1)
  hotel_id               Int                  @unique
  created_by             Int?
  name                   String               @db.VarChar(150)
  email                  String               @unique @db.VarChar(255)
  password               String               @db.VarChar(255)
  is_active              Boolean              @default(true)
  is_blocked             Boolean              @default(false)
  last_login_at          DateTime?
  login_attempts         Int                  @default(0)
  locked_until           DateTime?
  password_reset_token   String?              @db.VarChar(255)
  password_reset_expires DateTime?
  created_at             DateTime             @default(now())
  updated_at             DateTime             @updatedAt
  deleted_at             DateTime?
  hotel_admin_details    hotel_admin_details?
  creator                system_admins?       @relation(fields: [created_by], references: [system_admin_id])
  hotel                  hotels               @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)
  role                   roles                @relation(fields: [role_id], references: [role_id])

  @@index([email])
  @@index([created_by], map: "hotel_admins_created_by_fkey")
  @@index([role_id], map: "hotel_admins_role_id_fkey")
  @@map("hotel_admins")
}

model hotel_admin_details {
  hotel_admin_details_id Int          @id @default(autoincrement())
  hotel_admin_id         Int          @unique
  dob                    DateTime?    @db.Date
  phone                  String?      @db.VarChar(32)
  nid_no                 String?      @db.VarChar(50)
  address                String?      @db.Text
  passport               String?      @db.VarChar(50)
  manager_name           String?      @db.VarChar(150)
  manager_phone          String?      @db.VarChar(32)
  emergency_contact1     String?      @db.VarChar(100)
  emergency_contact2     String?      @db.VarChar(100)
  image_url              String?      @db.VarChar(500)
  updated_at             DateTime     @updatedAt
  hotel_admin            hotel_admins @relation(fields: [hotel_admin_id], references: [hotel_admin_id], onDelete: Cascade)

  @@map("hotel_admin_details")
}

model hotel_sub_admins {
  hotel_sub_admin_id      Int                      @id @default(autoincrement())
  role_id                 Int                      @default(2)
  hotel_id                Int
  created_by              Int?
  name                    String                   @db.VarChar(150)
  email                   String                   @unique @db.VarChar(255)
  password                String                   @db.VarChar(255)
  is_active               Boolean                  @default(true)
  is_blocked              Boolean                  @default(false)
  last_login_at           DateTime?
  login_attempts          Int                      @default(0)
  locked_until            DateTime?
  password_reset_token    String?                  @db.VarChar(255)
  password_reset_expires  DateTime?
  created_at              DateTime                 @default(now())
  updated_at              DateTime                 @updatedAt
  deleted_at              DateTime?
  hotel_sub_admin_details hotel_sub_admin_details?
  hotel                   hotels                   @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)
  role                    roles                    @relation(fields: [role_id], references: [role_id])

  @@index([email])
  @@index([hotel_id])
  @@index([role_id], map: "hotel_sub_admins_role_id_fkey")
  @@map("hotel_sub_admins")
}

model hotel_sub_admin_details {
  hotel_sub_admin_details_id Int              @id @default(autoincrement())
  hotel_sub_admin_id         Int              @unique
  phone                      String?          @db.VarChar(32)
  nid_no                     String?          @db.VarChar(50)
  image_url                  String?          @db.VarChar(500)
  updated_at                 DateTime         @updatedAt
  hotel_sub_admin            hotel_sub_admins @relation(fields: [hotel_sub_admin_id], references: [hotel_sub_admin_id], onDelete: Cascade)

  @@map("hotel_sub_admin_details")
}

model amenities {
  id              Int               @id @default(autoincrement())
  name            String            @unique @db.VarChar(150)
  icon            String?           @db.VarChar(100)
  context         AmenityContext    @default(BOTH)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now())
  hotel_amenities hotel_amenities[]
  room_amenities  room_amenities[]

  @@map("amenities")
}

model cities {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  image_url  String?  @db.VarChar(500)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("cities")
}

model hotel_images {
  id         Int      @id @default(autoincrement())
  hotel_id   Int
  image_url  String   @db.MediumText
  is_cover   Boolean  @default(false)
  created_at DateTime @default(now())
  hotel      hotels   @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  @@index([hotel_id])
  @@map("hotel_images")
}

model hotel_amenities {
  id         Int       @id @default(autoincrement())
  hotel_id   Int
  amenity_id Int
  created_at DateTime  @default(now())
  amenity    amenities @relation(fields: [amenity_id], references: [id], onDelete: Cascade)
  hotel      hotels    @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)

  @@unique([hotel_id, amenity_id])
  @@index([hotel_id])
  @@index([amenity_id], map: "hotel_amenities_amenity_id_fkey")
  @@map("hotel_amenities")
}

model hotel_rooms {
  hotel_room_id         Int                     @id @default(autoincrement())
  hotel_id              Int
  room_type             RoomType
  description           String?                 @db.Text
  base_price            Decimal                 @db.Decimal(12, 2)
  room_size             String?                 @db.VarChar(50)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  booking_rooms         booking_rooms[]
  hotel_room_details    hotel_room_details[]
  hotel_room_images     hotel_room_images[]
  hotel                 hotels                  @relation(fields: [hotel_id], references: [hotel_id], onDelete: Cascade)
  room_booking_trackers room_booking_trackers[]

  @@index([hotel_id])
  @@map("hotel_rooms")
}

model hotel_room_images {
  id            Int         @id @default(autoincrement())
  hotel_room_id Int
  image_url     String      @db.LongText
  is_cover      Boolean     @default(false)
  created_at    DateTime    @default(now())
  hotel_room    hotel_rooms @relation(fields: [hotel_room_id], references: [hotel_room_id], onDelete: Cascade)

  @@index([hotel_room_id])
  @@map("hotel_room_images")
}

model room_amenities {
  id                      Int                   @id @default(autoincrement())
  hotel_room_details_id   Int
  amenity_id              Int
  created_at              DateTime              @default(now())
  amenity                 amenities             @relation(fields: [amenity_id], references: [id], onDelete: Cascade)
  hotel_room_detail       hotel_room_details   @relation(fields: [hotel_room_details_id], references: [hotel_room_details_id], onDelete: Cascade)

  @@unique([hotel_room_details_id, amenity_id])
  @@index([hotel_room_details_id])
  @@index([amenity_id], map: "room_amenities_amenity_id_fkey")
  @@map("room_amenities")
}

model hotel_room_details {
  hotel_room_details_id Int                     @id @default(autoincrement())
  hotel_rooms_id        Int
  room_number           String                  @db.VarChar(50)
  room_size             String?                 @db.VarChar(50)
  bed_type              BedType?
  max_occupancy         Int                     @default(2)
  smoking_allowed       Boolean                 @default(false)
  pet_allowed           Boolean                 @default(false)
  image_url             String?                 @db.VarChar(500)
  status                RoomStatus              @default(AVAILABLE)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  deleted_at            DateTime?
  hotel_room            hotel_rooms             @relation(fields: [hotel_rooms_id], references: [hotel_room_id], onDelete: Cascade)
  room_amenities        room_amenities[]
  room_booking_trackers room_booking_trackers[]

  @@index([hotel_rooms_id])
  @@map("hotel_room_details")
}

model bookings {
  booking_id            Int                     @id @default(autoincrement())
  booking_reference     String                  @unique @db.VarChar(64)
  end_user_id           Int
  hotel_id              Int
  check_in              DateTime                @db.Date
  check_out             DateTime                @db.Date
  special_request       String?                 @db.Text
  status                BookingStatus           @default(RESERVED)
  reserved_until        DateTime?
  total_price           Decimal                 @db.Decimal(12, 2)
  locked_price          Decimal?                @db.Decimal(12, 2)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  booking_rooms         booking_rooms[]
  end_user              end_users               @relation(fields: [end_user_id], references: [end_user_id], onDelete: Cascade)
  hotel                 hotels                  @relation(fields: [hotel_id], references: [hotel_id])
  room_booking_trackers room_booking_trackers[]

  @@index([booking_reference])
  @@index([hotel_id, check_in, check_out])
  @@index([end_user_id, status])
  @@index([reserved_until])
  @@map("bookings")
}

model booking_rooms {
  booking_room_id Int         @id @default(autoincrement())
  booking_id      Int
  hotel_room_id   Int
  quantity        Int         @default(1)
  price_per_night Decimal     @db.Decimal(12, 2)
  nights          Int
  subtotal        Decimal     @db.Decimal(12, 2)
  created_at      DateTime    @default(now())
  booking         bookings    @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  hotel_room      hotel_rooms @relation(fields: [hotel_room_id], references: [hotel_room_id])

  @@index([booking_id])
  @@index([hotel_room_id])
  @@map("booking_rooms")
}

model room_booking_trackers {
  tracker_id            Int                @id @default(autoincrement())
  booking_id            Int
  hotel_room_details_id Int
  hotel_room_id         Int
  check_in              DateTime           @db.Date
  check_out             DateTime           @db.Date
  status                TrackerStatus      @default(RESERVED)
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  booking               bookings           @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  hotel_room_detail     hotel_room_details @relation(fields: [hotel_room_details_id], references: [hotel_room_details_id])
  hotel_room            hotel_rooms        @relation(fields: [hotel_room_id], references: [hotel_room_id])

  @@unique([hotel_room_details_id, check_in, check_out])
  @@index([hotel_room_id, check_in, check_out])
  @@index([booking_id])
  @@index([status])
  @@index([check_in])
  @@index([hotel_room_details_id, check_in, check_out])
  @@index([hotel_room_details_id, status, check_in, check_out])
  @@map("room_booking_trackers")
}

model blacklisted_tokens {
  id         Int       @id @default(autoincrement())
  token_hash String    @unique @db.VarChar(500)
  actor_id   Int
  actor_type ActorType
  expires_at DateTime
  created_at DateTime  @default(now())

  @@index([token_hash])
  @@index([expires_at])
  @@index([actor_id, actor_type])
  @@map("blacklisted_tokens")
}

enum ActorType {
  SYSTEM_ADMIN
  HOTEL_ADMIN
  HOTEL_SUB_ADMIN
  END_USER
}

enum AmenityContext {
  HOTEL
  ROOM
  BOTH
}

enum ApprovalStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

enum BookingStatus {
  RESERVED
  BOOKED
  EXPIRED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

enum TrackerStatus {
  RESERVED
  BOOKED
  EXPIRED
  CANCELLED
  CHECKED_IN
  CHECKED_OUT
}

enum RoomStatus {
  AVAILABLE
  UNAVAILABLE
  MAINTENANCE
}

// Enum-like fields used by the app for consistent filtering (hero search, filters sidebar, admin forms)
enum HotelType {
  hotel
  resort
  boutique
  hostel
}

enum RoomType {
  standard
  delux
  suite
  penthouse
}

enum BedType {
  Single
  Double
  Queen
  King
  Twin
}
